{
  "buildCommand": "cd frontend-v2 && npm install && npm run build",
  "outputDirectory": "frontend-v2/dist",
  "framework": "vite",
  "installCommand": "cd frontend-v2 && npm install",
  "regions": ["pdx1"],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://happy-dream-production-3527.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
