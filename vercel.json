{
  "buildCommand": "cd frontend-v2 && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "frontend-v2/dist",
  "installCommand": "cd frontend-v2 && npm install --legacy-peer-deps",
  "regions": ["pdx1"],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://backend-iota-sand-94.vercel.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
